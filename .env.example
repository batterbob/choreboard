# Choreify — environment config
# Copy to .env and fill in your values before first run.
# .env is gitignored — never commit it.

# Admin password: set before the first run.
# It is hashed into the database on startup and not re-read afterward.
# To change it later, use /admin/settings.
ADMIN_PASSWORD=change-me-before-first-run

# Port the app listens on. 7823 by default; change it in docker-compose.yml too if you update this.
PORT=7823

# Timezone — use a tz database name (e.g. America/Chicago, Europe/London)
TZ=America/New_York

# Set to 1 to enable the ?today= date override on all pages (for testing before the season starts).
CHORE_DEBUG=0

# Optional: push-monitor URL. The scheduler pings it every minute to confirm it's running.
# Works with Uptime Kuma (push monitor), Healthchecks.io, or any HTTP endpoint.
# Leave blank to disable.
HEALTHCHECK_URL=
